# Docker テスト用環境変数ファイルの例
# ローカル Docker コンテナでの動作確認用
# 使用方法: cp .env.docker.example .env.docker && 実際の値を設定

# Discord 設定（必須）
DISCORD_BOT_TOKEN=your_real_discord_bot_token_here
DISCORD_GUILD_ID=your_real_guild_id_here

# AI 設定（必須）
GEMINI_API_KEY=your_real_gemini_api_key_here

# Obsidian 設定
OBSIDIAN_VAULT_PATH=/app/vault

# サーバー設定
PORT=8080
HOST=0.0.0.0

# ログレベル
LOG_LEVEL=INFO

# オプショナル設定（必要に応じて）
GOOGLE_APPLICATION_CREDENTIALS=/app/.config/gcp-credentials.json
GARMIN_USERNAME=your_garmin_username_here
GARMIN_PASSWORD=your_garmin_password_here

# テスト用設定
ENVIRONMENT=development
DEBUG=true

# 注意事項:
# - 本番用の認証情報は使用しないでください
# - テスト専用の Discord サーバーを作成することを推奨します
# - このファイルは.gitignore に含まれているため、 Git にコミットされません